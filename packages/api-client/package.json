{
  "name": "@grid/api-client",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "openapi-typescript ../../docs/api/openapi.yaml -o src/schema.ts",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --out-dir dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.5.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
