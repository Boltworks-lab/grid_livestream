# Copy to .env (and apps/api/.env) and adjust. Never commit real secrets (PROJECT_BRIEF §3.7).

# apps/api
NODE_ENV=development
PORT=3001
# 5433 on the host: dev machine runs a native Windows PostgreSQL on 5432
DATABASE_URL=postgresql://grid:grid@localhost:5433/grid
REDIS_URL=redis://localhost:6379
# 32+ chars; REQUIRED (no default) in production
JWT_SECRET=dev-only-secret-change-me-0123456789abcdef
JWT_ACCESS_TTL=900
REFRESH_TTL_DAYS=30
