# Copy to .env (and apps/api/.env) and adjust. Never commit real secrets (PROJECT_BRIEF §3.7).

# apps/api
NODE_ENV=development
PORT=3001
# 5433 on the host: dev machine runs a native Windows PostgreSQL on 5432
DATABASE_URL=postgresql://grid:grid@localhost:5433/grid
REDIS_URL=redis://localhost:6379
# 32+ chars; REQUIRED (no default) in production
JWT_SECRET=dev-only-secret-change-me-0123456789abcdef
JWT_ACCESS_TTL=900
REFRESH_TTL_DAYS=30
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Stripe (test mode; webhook secret comes from `stripe listen` or the dashboard)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Sentry error tracking (all apps). Backend reads SENTRY_DSN; the Vite apps read
# VITE_SENTRY_DSN at build time (set in apps/web/.env and apps/admin/.env — may reuse
# the same DSN or use per-app projects). Empty = disabled.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# apps/web/.env and apps/admin/.env:
# VITE_SENTRY_DSN=

# ── Placeholders: blocked on owner credentials (see docs/deferred.md) ──
# EMAIL_API_KEY=            # Resend or Postmark — email OTP + receipts
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# APPLE_OAUTH_CLIENT_ID=
# SENTRY_DSN=
